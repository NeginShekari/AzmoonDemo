]
visualize_solution(grid1)## مثال‌های عملیdef visualize_solution(obstacle_grid):
    """
    نمایش بصری حل مسئله
    """
    if not obstacle_grid or not obstacle_grid[0]:
        print("ماتریس خالی است!")
        return
    
    m, n = len(obstacle_grid), len(obstacle_grid[0])
    
    print("ماتریس موانع:")
    for i in range(m):
        row_str = ""
        for j in range(n):
            if obstacle_grid[i][j] == 1:
                row_str += "🚫 "
            else:
                row_str += "⬜ "
        print(row_str)
    
    # محاسبه جدول DP
    if obstacle_grid[0][0] == 1 or obstacle_grid[m-1][n-1] == 1:
        print("\nنقطه شروع یا پایان مسدود است!")
        return
    
    dp = [[0] * n for _ in range(m)]
    dp[0][0] = 1
    
    # پر کردن جدول DP
    for j in range(1, n):
        if obstacle_grid[0][j] == 0:
            dp[0][j] = dp[0][j-1]
    
    for i in range(1, m):
        if obstacle_grid[i][0] == 0:
            dp[i][0] = dp[i-1][0]
    
    for i in range(1, m):
        for j in range(1, n):
            if obstacle_grid[i][j] == 0:
                dp[i][j] = dp[i-1][j] + dp[i][j-1]
    
    print("\nجدول تعداد مسیرها:")
    for i in range(m):
        row_str = ""
        for j in range(n):
            if obstacle_grid[i][j] == 1:
                row_str += "  X "
            else:
                row_str += f"{dp[i][j]:3d} "
        print(row_str)
    
    result = dp[m-1][n-1]
    print(f"\n🎯 تعداد کل مسیرهای منحصر به فرد: {result}")
    
    return resultdef unique_paths_with_obstacles(obstacle_grid):
    """
    محاسبه تعداد مسیرهای منحصر به فرد با استفاده از برنامه‌نویسی پویا
    
    Args:
        obstacle_grid: ماتریس دوبعدی (0 = آزاد، 1 = مانع)
    
    Returns:
        int: تعداد مسیرهای منحصر به فرد
    """
    if not obstacle_grid or not obstacle_grid[0]:
        return 0
    
    m, n = len(obstacle_grid), len(obstacle_grid[0])
    
    # بررسی نقاط شروع و پایان
    if obstacle_grid[0][0] == 1 or obstacle_grid[m-1][n-1] == 1:
        return 0
    
    # ایجاد جدول DP
    dp = [[0] * n for _ in range(m)]
    dp[0][0] = 1
    
    # پر کردن ردیف اول
    for j in range(1, n):
        if obstacle_grid[0][j] == 0:
            dp[0][j] = dp[0][j-1]
    
    # پر کردن ستون اول
    for i in range(1, m):
        if obstacle_grid[i][0] == 0:
            dp[i][0] = dp[i-1][0]
    
    # پر کردن باقی جدول
    for i in range(1, m):
        for j in range(1, n):
            if obstacle_grid[i][j] == 0:
                dp[i][j] = dp[i-1][j] + dp[i][j-1]
    
    return dp[m-1][n-1]# مسئله: محاسبه مسیرهای منحصر به فرد در ماتریس با موانع

## شرح مسئله
یک ربات در گوشه بالا چپ یک ماتریس m×n قرار دارد. ربات می‌خواهد به گوشه پایین راست برسد.

- ربات فقط می‌تواند به سمت راست یا پایین حرکت کند
- برخی خانه‌ها دارای مانع هستند (با عدد 1 نشان داده می‌شوند)
- خانه‌های آزاد با عدد 0 نشان داده می‌شوند

**هدف:** محاسبه تعداد مسیرهای منحصر به فرد ممکن